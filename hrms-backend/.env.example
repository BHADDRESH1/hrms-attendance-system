# App Configurations
APP_NAME="HRMS Attendance API"
DEBUG=True
API_V1_STR="/api/v1"

# Database Connections (asyncpg is used for async SQLAlchemy calls)
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/hrms_db"

# Supabase Auth Configurations
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret-used-for-local-token-verification"
